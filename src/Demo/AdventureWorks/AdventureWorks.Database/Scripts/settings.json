{
  // can be used to configure project
  // can be overwritten in separate migration folder

  // Optional. Binds this project to a database; max 128 characters.
  "ProjectId": "adventureworks",

  /* Options:
      Deployment - full deployment will be wrapped withing transaction
      Migration - each migration wrapped by transaction
      None - no transactions introduced */
  "TransactionWrapLevel": "Migration",

  /* Options:
      ReadCommitted,
      RepeatableRead,
      Serializable,
      Snapshot (MSSQL only; requires ALLOW_SNAPSHOT_ISOLATION ON) */
  "TransactionIsolationLevel": "Serializable",

  /* Parallel code deploy is forced to serial when TransactionWrapLevel is Deployment. */

  /* Search pattern for the test files. 
     Test files can be executed in the end of deployment. */
  "TestFilePatterns": [ "test.*.sql", "t.*.sql", "*.test.sql", "*.t.sql" ],

  "CodeSubFoldersDeploymentOrder": [
    "Views",
    "Triggers",
    "Functions"
  ],

  /* MigrationChecksumMode: Strict (default) | Warn */
  "MigrationChecksumMode": "Strict",

  /* When enabled, a second parallel deploy waits until the first completes. Default: true */
  "DeployLockEnabled": true
}
